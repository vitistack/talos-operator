DEVELOPMENT=true
LOG_LEVEL=info
LOG_JSON=false
LOG_COLORIZE_LINE=true
LOG_ADD_CALLER=true
LOG_UNESCAPED_MULTILINE=true
LOG_DISABLE_STACKTRACE=false
TENANT_CONFIGMAP_NAME=talos-tenant-config
TENANT_CONFIGMAP_NAMESPACE=default
TENANT_CONFIGMAP_DATA_KEY=config.yaml
TALOS_VM_INSTALL_IMAGE_DEFAULT=factory.talos.dev/nocloud-installer/b0f2a8b575460a3dcb1234cc081c73c88e795aaef36eda9b88a6f4dddbd49365:v1.12.7
TALOS_VM_INSTALL_IMAGE_KUBEVIRT=factory.talos.dev/nocloud-installer/b0f2a8b575460a3dcb1234cc081c73c88e795aaef36eda9b88a6f4dddbd49365:v1.12.7
# Comma-separated list of Talos system extensions every node must have. When
# any node is missing one, the operator triggers a Talos upgrade with the
# matching TALOS_VM_INSTALL_IMAGE_* image (which must have these extensions
# baked into its schematic). Empty disables the check.
TALOS_REQUIRED_EXTENSIONS=siderolabs/iscsi-tools,siderolabs/qemu-guest-agent,siderolabs/trident-iscsi-tools,siderolabs/util-linux-tools
# Minutes between Talos upgrade triggers for the same node + image. Default 10.
TALOS_EXTENSION_COOLDOWN_MINUTES=10
BOOT_IMAGE=https://factory.talos.dev/image/b0f2a8b575460a3dcb1234cc081c73c88e795aaef36eda9b88a6f4dddbd49365/v1.12.7/nocloud-amd64.iso
TALOS_VERSION=v1.12.7
DEFAULT_KUBERNETES_VERSION=1.35.4
NAME_KUBERNETES_PROVIDER=talos-provider
TALOS_PREDICTABLE_NETWORK_NAMES=true
ENDPOINT_MODE=networkconfiguration
BOOT_IMAGE_SOURCE=pxe
